{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TinkerVault 42",
  "version": "42.1.0",
  "identifier": "com.madtinkersworkshop.tinkervault42",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TinkerVault 42",
        "width": 1180,
        "height": 680,
        "minWidth": 1060,
        "minHeight": 620,
        "resizable": true,
        "maximized" : true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}